<% if @user.errors.any? %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% @user.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
<% content_for :title, "Criar Conta no ZenCrowd" %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="card shadow-sm border-0 mt-5">
      <div class="card-body p-4">
        <h2 class="mb-4 text-center"><i class="bi bi-person-plus"></i> Criar Conta</h2>
        <%= form_with model: @user, url: signup_path, method: :post, local: true, class: "needs-validation" do |f| %>
          <div class="mb-3">
            <%= f.label :name, "Nome", class: "form-label" %>
            <%= f.text_field :name, class: "form-control", required: true, autofocus: true, autocomplete: "name" %>
          </div>
          <div class="mb-3">
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true, autocomplete: "username" %>
          </div>
          <div class="mb-3">
            <%= f.label :password, "Senha", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true, autocomplete: "new-password" %>
          </div>
          <div class="mb-3">
            <%= f.label :password_confirmation, "Confirme a Senha", class: "form-label" %>
            <%= f.password_field :password_confirmation, class: "form-control", required: true, autocomplete: "new-password" %>
          </div>
          <div class="mb-3">
            <%= f.label :role, "Papel", class: "form-label" %>
            <%= f.select :role,
                         options_for_select([
                           ['Administrador', 'admin'],
                           ['Uploader', 'uploader'],
                           ['Anotador', 'annotator'],
                           ['Revisor', 'reviewer']
                         ], @user.role.presence),
                         { prompt: 'Selecione o papel' },
                         class: "form-select" %>
          </div>
          <div class="d-grid gap-2">
            <%= f.submit "Criar Conta", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>
        <div class="mt-3 text-center">
          <%= link_to "Já tem conta? Entrar", login_path %>
        </div>
      </div>
    </div>
  </div>
</div>
