<% content_for :title, "Upload de Imagem" %>

<div class="row justify-content-center">
  <div class="col-md-9 col-lg-8">
    <div class="card shadow-sm border-0 mt-4">
      <div class="card-body p-4">
        <h2 class="mb-4 text-center"><i class="bi bi-image"></i> Upload de Imagem</h2>

        <% if @imagem.errors.any? %>
          <div class="alert alert-danger">
            <strong>Nao foi possivel salvar a imagem:</strong>
            <ul class="mb-0 mt-2">
              <% @imagem.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @imagem, url: imagens_path, method: :post, local: true, html: { multipart: true } do |f| %>
          <div class="mb-3">
            <%= f.label :arquivo, 'Arquivo da Imagem', class: 'form-label' %>
            <%= f.file_field :arquivo, class: 'form-control', required: true, accept: 'image/jpeg,image/jpg,image/png' %>
          </div>

          <div class="mb-3">
            <%= f.label :data_hora, 'Data e Hora', class: 'form-label' %>
            <%= f.datetime_local_field :data_hora,
                  class: 'form-control',
                  required: true,
                  value: @imagem.data_hora&.in_time_zone&.strftime('%Y-%m-%dT%H:%M') %>
          </div>

          <div class="mb-3">
            <%= f.label :gps_location, 'GPS', class: 'form-label' %>
            <%= f.text_field :gps_location, class: 'form-control', required: true, placeholder: '-23.550520,-46.633308' %>
          </div>

          <div class="mb-3">
            <%= f.label :cidade, 'Cidade', class: 'form-label' %>
            <%= f.text_field :cidade, class: 'form-control', required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :local, 'Local', class: 'form-label' %>
            <%= f.text_field :local, class: 'form-control', required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :nome_do_evento, 'Nome do Evento', class: 'form-label' %>
            <%= f.text_field :nome_do_evento, class: 'form-control' %>
          </div>

          <div class="mb-3">
            <%= f.label :posicao, 'Posicao', class: 'form-label' %>
            <%= f.select :posicao,
              Imagem.defined_enums.fetch('posicao').keys.map { |key| [key.humanize, key] },
                  { include_blank: 'Selecione (opcional)' },
                  { class: 'form-select' } %>
          </div>

          <% tile_select_size = [[@tiles.size, 3].max, 8].min %>
          <div class="mb-4">
            <%= f.label :tile_ids, 'Tiles associados (opcional)', class: 'form-label' %>
            <%= f.select :tile_ids,
                  options_for_select(
                    @tiles.map { |tile| ["##{tile.id} - #{tile.original_filename} (#{human_tile_status(tile.status)})", tile.id] },
                    @imagem.tile_ids
                  ),
                  {},
                  { multiple: true, class: 'form-select', size: tile_select_size } %>
            <div class="form-text">Segure Ctrl (ou Cmd no Mac) para selecionar mais de um tile.</div>
          </div>

          <div class="d-grid gap-2">
            <%= f.submit 'Enviar', class: 'btn btn-primary btn-lg' %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
