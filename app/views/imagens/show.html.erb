<% content_for :title, "Imagem ##{@imagem.id}" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Imagem <%= @imagem.id %></h1>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to 'Nova Imagem', new_imagem_path, class: 'btn btn-primary' %>
    <%= link_to 'Tiles', tiles_path, class: 'btn btn-outline-primary' %>
    <%= button_to 'Deletar',
                  imagem_path(@imagem),
                  method: :delete,
                  class: 'btn btn-outline-danger',
                  form: {
                    class: 'd-inline-block',
                    data: {
                      turbo_confirm: 'Tem certeza que deseja deletar esta imagem? Essa acao nao pode ser desfeita.'
                    }
                  } %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <% if @imagem.arquivo.attached? %>
          <%= image_tag url_for(@imagem.arquivo), class: 'img-fluid rounded', alt: "Imagem #{@imagem.id}" %>
          <p class="text-muted mt-3 mb-0">
            <strong>Arquivo:</strong> <%= @imagem.arquivo.filename.to_s %>
          </p>
        <% else %>
          <div class="alert alert-warning mb-0">Arquivo da imagem nao encontrado.</div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h5 class="card-title mb-3">Metadados da Imagem</h5>

        <dl class="row mb-0">
          <dt class="col-sm-5">ID</dt>
          <dd class="col-sm-7"><%= @imagem.id %></dd>

          <dt class="col-sm-5">Data e Hora</dt>
          <dd class="col-sm-7"><%= l(@imagem.data_hora, format: :short) %></dd>

          <dt class="col-sm-5">Cidade</dt>
          <dd class="col-sm-7"><%= @imagem.cidade %></dd>

          <dt class="col-sm-5">Local</dt>
          <dd class="col-sm-7"><%= @imagem.local %></dd>

          <dt class="col-sm-5">Evento</dt>
          <dd class="col-sm-7"><%= @imagem.nome_do_evento.presence || '-' %></dd>

          <dt class="col-sm-5">Posicao</dt>
          <dd class="col-sm-7"><%= @imagem.posicao.present? ? @imagem.posicao.humanize : '-' %></dd>
        </dl>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm mt-4">
  <div class="card-body">
    <h5 class="card-title">Tiles Associados</h5>

    <% if @imagem.tiles.any? %>
      <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Arquivo</th>
              <th>Status</th>
              <th>Valor da Tarefa</th>
            </tr>
          </thead>
          <tbody>
            <% @imagem.tiles.order(created_at: :desc).each do |tile| %>
              <tr>
                <td><%= tile.id %></td>
                <td><%= link_to tile.original_filename, tile_path(tile), class: 'text-decoration-none' %></td>
                <td><%= human_tile_status(tile.status) %></td>
                <td><%= number_with_precision(tile.task_value, precision: 2) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="alert alert-info mb-0">Nenhum tile associado a esta imagem.</div>
    <% end %>
  </div>
</div>
