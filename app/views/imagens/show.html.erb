<% content_for :title, "Imagem ##{@imagem.id}" %>
<% admin_editable = current_user&.admin? %>
<% zenith_tolerance_degrees = AppSetting.zenith_tolerance_degrees %>
<% gimbal_pitch_degree = @imagem.gimbal_pitch_degree %>
<% zenital = @imagem.zenital?(tolerance_degrees: zenith_tolerance_degrees) %>

<div class="d-flex justify-content-between align-items-center page-header">
  <h1 class="page-title">Imagem <%= @imagem.id %></h1>
  <% if admin_editable %>
    <div class="d-flex flex-wrap gap-2">
      <%= button_to 'Deletar',
                    imagem_path(@imagem),
                    method: :delete,
                    class: 'btn btn-outline-danger',
                    form: {
                      class: 'd-inline-block',
                      data: {
                        turbo_confirm: 'Tem certeza que deseja deletar esta imagem? Essa acao nao pode ser desfeita.'
                      }
                    } %>
    </div>
  <% end %>
</div>

<div class="row g-4" <%= admin_editable ? 'data-controller="grid-overlay"'.html_safe : '' %>>
  <div class="col-lg-7">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <% if @imagem.arquivo.attached? %>
          <div class="grid-overlay-preview">
            <%= image_tag url_for(@imagem.arquivo), class: 'img-fluid', alt: "Imagem #{@imagem.id}" %>
            <div class="grid-overlay-layer" data-grid-overlay-target="overlay"></div>
          </div>

          <p class="text-muted mt-3 mb-0">
            <strong>Arquivo:</strong> <%= @imagem.arquivo.filename.to_s %>
          </p>
        <% else %>
          <div class="alert alert-warning mb-0">Arquivo da imagem nao encontrado.</div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h5 class="card-title mb-3">Metadados da Imagem</h5>

        <dl class="row mb-0">
          <dt class="col-sm-5">ID</dt>
          <dd class="col-sm-7"><%= @imagem.id %></dd>

          <dt class="col-sm-5">Data e Hora</dt>
          <dd class="col-sm-7"><%= l(@imagem.data_hora, format: :short) %></dd>

          <dt class="col-sm-5">Zenital</dt>
          <dd class="col-sm-7">
            <% if zenital.nil? %>
              <span class="badge text-bg-secondary" title="Sem metadado de pitch do gimbal">Sem pitch</span>
            <% elsif zenital %>
              <span class="badge text-bg-success" title="Pitch do gimbal: <%= format('%.2f', gimbal_pitch_degree) %> deg | Tolerancia: +/-<%= zenith_tolerance_degrees %> deg">Sim</span>
            <% else %>
              <span class="badge text-bg-danger" title="Pitch do gimbal: <%= format('%.2f', gimbal_pitch_degree) %> deg | Tolerancia: +/-<%= zenith_tolerance_degrees %> deg">Nao</span>
            <% end %>
          </dd>

          <dt class="col-sm-5">Cidade</dt>
          <dd class="col-sm-7"><%= @imagem.cidade %></dd>

          <dt class="col-sm-5">Local</dt>
          <dd class="col-sm-7"><%= @imagem.local %></dd>

          <dt class="col-sm-5">Evento</dt>
          <% if admin_editable %>
            <dd class="col-sm-7" data-controller="evento-autocomplete-inline">
              <button type="button"
                      class="btn btn-link p-0 text-start text-decoration-none"
                      data-evento-autocomplete-inline-target="display"
                      data-action="evento-autocomplete-inline#open">
                <span class="d-block"><%= @imagem.evento&.nome || 'Sem evento associado' %></span>
              </button>

              <div class="d-none mt-2" data-evento-autocomplete-inline-target="editor">
                <%= form_with scope: :imagem,
                        url: imagem_path(@imagem),
                        method: :patch,
                        local: true do |f| %>
                  <%= f.hidden_field :evento_id,
                                     value: nil,
                                     data: { 'evento-autocomplete-inline-target': 'eventoIdInput' } %>

                  <%= f.text_field :evento_autocomplete,
                                   value: (@imagem.evento.present? ? "#{@imagem.evento.nome} - ##{@imagem.evento.id}" : ''),
                                   class: 'form-control',
                                   list: "eventos-list-#{@imagem.id}",
                                   placeholder: 'Digite para buscar evento',
                                   data: {
                                     action: 'input->evento-autocomplete-inline#sync blur->evento-autocomplete-inline#sync',
                                     'evento-autocomplete-inline-target': 'nomeInput'
                                   } %>

                  <datalist id="eventos-list-<%= @imagem.id %>">
                    <% @eventos.each do |evento| %>
                      <option value="<%= "#{evento.nome} - ##{evento.id}" %>"
                              data-evento-id="<%= evento.id %>"
                              data-evento-autocomplete-inline-target="option"></option>
                    <% end %>
                  </datalist>

                  <div class="mt-2">
                    <%= f.label :pasta, 'Pasta', class: 'form-label mb-1' %>
                    <%= f.text_field :pasta,
                                     value: @imagem.pasta,
                                     class: 'form-control',
                                     placeholder: 'Ex.: Pasta A' %>
                  </div>

                  <div class="d-flex gap-2 mt-2">
                    <%= f.submit 'Salvar evento', class: 'btn btn-outline-primary btn-sm' %>
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm"
                            data-action="evento-autocomplete-inline#close">Cancelar</button>
                  </div>
                <% end %>
              </div>
            </dd>
          <% else %>
            <dd class="col-sm-7"><%= @imagem.evento&.nome || 'Sem evento associado' %></dd>
          <% end %>
        </dl>

        <% if admin_editable && @imagem.arquivo.attached? && !zenital.equal?(false) %>
          <hr class="my-4">

          <h6 class="mb-2">Seletor de Grade </h6>
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
              <span class="text-muted">Grade selecionada:</span>
              <span class="badge text-bg-success" data-grid-overlay-target="selectionLabel">1x1</span>
            </div>
          </div>

          <div class="grid-picker mt-3" data-action="mouseleave->grid-overlay#restoreSelection">
            <% (1..4).each do |row| %>
              <% (1..4).each do |col| %>
                <button type="button"
                        class="grid-picker-cell"
                        data-grid-overlay-target="cell"
                        data-row="<%= row %>"
                        data-col="<%= col %>"
                        data-action="mouseenter->grid-overlay#hoverCell click->grid-overlay#selectCell"
                        aria-label="Selecionar grade <%= row %> por <%= col %>">
                </button>
              <% end %>
            <% end %>
          </div>

          <% confirm_cut_message = if @imagem.tiles.any?
                                    'Esta imagem ja possui tiles associados. Deseja apagar os tiles atuais e gerar novos recortes?'
                                  else
                                    'Deseja cortar esta imagem usando a grade selecionada?'
                                  end %>

          <%= form_with url: cortar_imagem_path(@imagem), method: :post, local: true, class: 'mt-3',
                data: {
                  controller: 'tile-cut-progress',
                  action: 'submit->tile-cut-progress#submit'
                } do %>
            <%= hidden_field_tag :rows,
                                 1,
                                 id: 'cut_rows',
                                 data: {
                                   grid_overlay_target: 'rowsInput',
                                   tile_cut_progress_target: 'rowsInput'
                                 } %>
            <%= hidden_field_tag :cols,
                                 1,
                                 id: 'cut_cols',
                                 data: {
                                   grid_overlay_target: 'colsInput',
                                   tile_cut_progress_target: 'colsInput'
                                 } %>

            <%= button_tag 'Cortar',
                           type: 'submit',
                           class: 'btn btn-success mt-3',
                           data: {
                             turbo_confirm: confirm_cut_message,
                             tile_cut_progress_target: 'submit'
                           } %>

            <div class="mt-3 d-none" data-tile-cut-progress-target="progressWrapper" aria-live="polite">
              <div class="progress" role="progressbar" aria-label="Progresso do corte de tiles">
                <div class="progress-bar" data-tile-cut-progress-target="progressBar" style="width: 0%;">0%</div>
              </div>
              <div class="small text-muted mt-2" data-tile-cut-progress-target="status">Aguardando início do corte.</div>
            </div>

            <div class="alert alert-danger mt-3 mb-0 d-none" data-tile-cut-progress-target="error"></div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm mt-4">
  <div class="card-body">
    <h5 class="card-title">Tiles Associados</h5>

    <% if @tiles.any? %>
      <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>Arquivo</th>
              <th>Status</th>
              <th>Qtd. estimada</th>
              <th>Valor da Tarefa</th>
            </tr>
          </thead>
          <tbody>
            <% @tiles.each do |tile| %>
              <tr>
                <td><%= tile.id %></td>
                <td>
                  <%= link_to middle_truncate(tile.original_filename, max_length: 34),
                              tile_path(tile),
                              class: 'text-decoration-none',
                              title: tile.original_filename %>
                </td>
                <td><%= human_tile_status(tile.status) %></td>
                <td><%= tile.head_count.present? ? tile.head_count : '-' %></td>
                <td>
                  <% if tile.task_value.present? %>
                    <%= number_to_currency(tile.task_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @tiles.respond_to?(:current_page) %>
        <div class="d-flex justify-content-center mt-3">
          <%= paginate @tiles %>
        </div>
      <% end %>
    <% else %>
      <div class="alert alert-info mb-0">Nenhum tile associado a esta imagem.</div>
    <% end %>
  </div>
</div>
