<% content_for :title, "Entrar no ZenCrowd" %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-sm border-0 mt-5">
      <div class="card-body p-4">
        <h2 class="mb-4 text-center"><i class="bi bi-box-arrow-in-right"></i> Entrar</h2>
        <%= form_with url: login_path, method: :post, local: true, class: "needs-validation" do |f| %>
          <div class="mb-3">
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email, class: "form-control", required: true, autofocus: true, autocomplete: "username" %>
          </div>
          <div class="mb-3">
            <%= f.label :password, "Senha", class: "form-label" %>
            <%= f.password_field :password, class: "form-control", required: true, autocomplete: "current-password" %>
          </div>
          <div class="d-grid gap-2">
            <%= f.submit "Entrar", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>
        <div class="mt-3 text-center">
          <a href="#">Esqueceu a senha?</a>
        </div>
      </div>
    </div>
  </div>
</div>
