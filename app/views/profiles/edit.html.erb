<div class="container py-5">
  <div class="row mb-4">
    <div class="col-12 text-center">
      <h1 class="display-5 fw-bold text-primary mb-2">Meu Perfil</h1>
      <p class="text-muted">Faça a gestão dos seus dados cadastrais e preferências de segurança.</p>
    </div>
  </div>

  <% if @user.errors.any? %>
    <div class="row justify-content-center mb-4">
      <div class="col-lg-8">
        <div class="alert alert-danger shadow-sm border-0">
          <h6 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Foram encontrados erros:</h6>
          <ul class="mb-0 small">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="row justify-content-center g-4">
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
          <h5 class="fw-bold mb-0"><i class="bi bi-person-lines-fill text-primary me-2"></i>Informações Pessoais</h5>
        </div>
        <div class="card-body p-4">
          
          <%= form_with model: @user, url: profile_path, method: :patch, local: true do |f| %>
            
            <div class="mb-3">
              <%= f.label :name, "Nome Completo", class: "form-label fw-semibold" %>
              <%= f.text_field :name, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :email, "Endereço de E-mail", class: "form-label fw-semibold text-muted" %>
              <%= f.email_field :email, class: "form-control bg-light text-muted", disabled: true, readonly: true %>
              <div class="form-text small"><i class="bi bi-info-circle"></i> Por motivos de segurança, o e-mail não pode ser alterado por aqui.</div>
            </div>

            <div class="row mb-4">
              <div class="col-6">
                <label class="form-label fw-semibold text-muted">Nível de Acesso</label>
                <div class="p-2 bg-light border rounded text-center text-muted fw-bold text-uppercase small">
                  <%= @user.role %>
                </div>
              </div>
              <div class="col-6">
                <label class="form-label fw-semibold text-muted">Pagamentos Pendentes</label>
                <div class="p-2 bg-light border rounded text-center text-success fw-bold small">
                  R$ <%= number_with_precision(@user.requested_payment_reais, precision: 2) %>
                </div>
              </div>
            </div>

            <div class="d-grid mt-auto">
              <%= f.submit "Atualizar Nome", class: "btn btn-outline-primary" %>
            </div>
          <% end %>

        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card border-0 shadow-sm border-top border-warning border-3 h-100">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
          <h5 class="fw-bold mb-0"><i class="bi bi-shield-lock-fill text-warning me-2"></i>Segurança</h5>
        </div>
        <div class="card-body p-4">
          
          <p class="text-muted small mb-4">Se deseja alterar a sua senha de acesso, preencha os campos abaixo. É obrigatório fornecer a senha atual.</p>

          <%= form_with model: @user, url: profile_path, method: :patch, local: true do |f| %>
            
            <div class="mb-4 bg-light p-3 rounded border">
              <%= f.label :current_password, "Senha Atual", class: "form-label fw-bold text-danger" %>
              <%= f.password_field :current_password, class: "form-control", placeholder: "Digite a senha atual" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "Nova Senha", class: "form-label fw-semibold" %>
              <%= f.password_field :password, class: "form-control", placeholder: "Mínimo de 6 caracteres" %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, "Confirmar Nova Senha", class: "form-label fw-semibold" %>
              <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Repita a nova senha" %>
            </div>

            <div class="d-grid mt-auto">
              <%= f.submit "Alterar Senha", class: "btn btn-warning fw-bold text-dark" %>
            </div>
          <% end %>

        </div>
      </div>
    </div>

  </div>
</div>