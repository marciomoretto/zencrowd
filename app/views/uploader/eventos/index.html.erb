<% content_for :title, 'Eventos' %>

<div class="d-flex justify-content-between align-items-center page-header">
  <div>
    <h1 class="page-title">Eventos</h1>
    <p class="text-muted mb-0">Gerencie os eventos e associe imagens.</p>
  </div>
  <%= link_to 'Novo Evento', new_uploader_evento_path, class: 'btn btn-primary' %>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <%= form_with url: uploader_eventos_path, method: :get, local: true, class: 'row g-3 align-items-end' do %>
      <div class="col-md-4">
        <%= label_tag :cidade, 'Cidade', class: 'form-label' %>
        <%= select_tag :cidade,
                       options_for_select([['Todas', '']] + @cidades.map { |cidade| [cidade, cidade] }, @cidade_filter),
                       class: 'form-select' %>
      </div>

      <div class="col-md-4">
        <%= label_tag :categoria, 'Categoria', class: 'form-label' %>
        <%= select_tag :categoria,
                       options_for_select([
                         ['Todas', ''],
                         ['Direita', 'direita'],
                         ['Esquerda', 'esquerda'],
                         ['Outro', 'outro'],
                         ['Sem categoria', 'sem_categoria']
                       ], @categoria_filter),
                       class: 'form-select' %>
      </div>

      <%= hidden_field_tag :sort, @sort %>
      <%= hidden_field_tag :direction, @direction %>

      <div class="col-md-auto">
        <%= submit_tag 'Aplicar filtro', class: 'btn btn-primary' %>
      </div>

      <div class="col-md-auto">
        <%= link_to 'Limpar', uploader_eventos_path, class: 'btn btn-outline-secondary' %>
      </div>
    <% end %>
  </div>
</div>

<%
sortable_header = lambda do |label, column|
  next_direction = (@sort == column && @direction.to_s == 'asc') ? 'desc' : 'asc'
  icon_class = if @sort == column
                 @direction.to_s == 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill'
               else
                 'bi-arrow-down-up'
               end

  link_to uploader_eventos_path(request.query_parameters.merge(sort: column, direction: next_direction)),
          class: 'text-decoration-none text-dark d-inline-flex align-items-center gap-1' do
    safe_join([
      content_tag(:span, label),
      content_tag(:i, nil, class: "bi #{icon_class} small text-secondary", aria: { hidden: true })
    ])
  end
end
%>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <% if @eventos.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nome</th>
              <th>Categoria</th>
              <th><%= sortable_header.call('Data', 'data') %></th>
              <th>Cidade</th>
              <th>Local</th>
              <th>Imagens</th>
            </tr>
          </thead>
          <tbody>
            <% @eventos.each do |evento| %>
              <tr id="evento-<%= evento.id %>">
                <td><strong><%= link_to evento.nome, uploader_evento_path(evento), class: 'text-decoration-none' %></strong></td>
                <td>
                  <span class="btn btn-sm evento-categoria-badge <%= evento_categoria_button_class(evento.categoria) %> disabled text-start"
                        aria-disabled="true">
                    <%= evento.categoria.present? ? evento.categoria.humanize : 'Sem categoria' %>
                  </span>
                </td>
                <td><%= evento.data.present? ? evento.data.strftime('%d/%m/%Y') : 'Nao informada' %></td>
                <td><%= evento.cidade.presence || 'Nao informada' %></td>
                <td><%= evento.local.presence || 'Nao informado' %></td>
                <td><span class="badge text-bg-secondary"><%= evento.imagens.size %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @eventos.respond_to?(:current_page) %>
        <div class="d-flex justify-content-center p-3 pb-0">
          <%= paginate @eventos %>
        </div>
      <% end %>
    <% else %>
      <div class="p-4">
        <div class="alert alert-info mb-0">Nenhum evento cadastrado.</div>
      </div>
    <% end %>
  </div>
</div>
