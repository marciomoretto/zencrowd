<% evento_data = @evento.data&.strftime('%d/%m/%y') || '--/--/----' %>
<% evento_cidade = @evento.cidade.presence || 'Sem cidade' %>
<% selected_rows = @saved_grid_rows.to_i.positive? ? @saved_grid_rows.to_i : 1 %>
<% selected_cols = @saved_grid_cols.to_i.positive? ? @saved_grid_cols.to_i : 1 %>
<% has_saved_grid = @has_saved_grid == true %>
<% grid_piece_counts = @grid_piece_counts.is_a?(Hash) ? @grid_piece_counts : {} %>
<% has_points_preview = @latest_points_preview_url.present? %>
<% content_for :title, "Mosaico #{@evento.nome} - #{evento_cidade} #{evento_data}" %>

<% progress_wrapper_class = @mosaic_status_url.present? ? 'card shadow-sm border-0 mb-4' : 'card shadow-sm border-0 mb-4 d-none' %>
<% preview_wrapper_class = @latest_mosaic_preview_url.present? ? 'card shadow-sm border-0 mb-4' : 'card shadow-sm border-0 mb-4 d-none' %>

<div data-controller="mosaic-progress"
  <% if @mosaic_status_url.present? %>data-mosaic-progress-status-url-value="<%= @mosaic_status_url %>"<% end %>>
  <div class="d-flex justify-content-between align-items-center page-header gap-2">
    <div>
      <h1 class="page-title">Mosaico <%= @evento.nome %> - <%= evento_cidade %> <%= evento_data %></h1>
      <h2 class="h4 fw-semibold mb-0"><%= @pasta_nome %></h2>
    </div>

    <div class="d-flex gap-2 align-items-center">
      <%= button_to 'Gerar novamente',
                    render_mosaic_uploader_evento_path(@evento, pasta: @pasta_param),
                    method: :post,
                    class: 'btn btn-outline-primary',
                    form: {
                      class: 'd-inline-block',
                      data: {
                        turbo_confirm: "Gerar mosaico para a pasta #{@pasta_nome}?"
                      }
                    } %>
      <%= link_to 'Voltar para pasta', pasta_uploader_evento_path(@evento, pasta: @pasta_param), class: 'btn btn-outline-secondary' %>
    </div>
  </div>

  <div class="<%= progress_wrapper_class %>" data-mosaic-progress-target="progressWrapper" aria-live="polite">
    <div class="card-body">
      <h2 class="h6 mb-3">Gerando mosaico</h2>
      <div class="progress" role="progressbar" aria-label="Progresso de geracao do mosaico">
        <div class="progress-bar progress-bar-striped progress-bar-animated" data-mosaic-progress-target="progressBar" data-progress-value="0" style="width: 0%;">0%</div>
      </div>
      <div class="small text-muted mt-2" data-mosaic-progress-target="status"><%= @mosaic_status_url.present? ? 'Aguardando inicio.' : 'Nenhum processamento em andamento.' %></div>
      <div class="alert alert-danger mt-3 mb-0 d-none" data-mosaic-progress-target="error"></div>
    </div>
  </div>

    <div class="<%= preview_wrapper_class %>"
      data-mosaic-progress-target="previewWrapper"
      data-controller="grid-overlay image-zoom"
      data-grid-overlay-grid-associated-value="<%= has_saved_grid %>"
      data-grid-overlay-piece-counts-value="<%= grid_piece_counts.to_json %>"
      data-grid-overlay-base-image-url-value="<%= @latest_mosaic_preview_url %>"
      data-grid-overlay-points-image-url-value="<%= @latest_points_preview_url.to_s %>">
    <div class="card-body">
      <h2 class="h6 mb-3">Mosaico gerado</h2>
      <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div class="small text-muted">Zoom do mosaico (com foco na imagem, use o scroll do mouse)</div>
        <div class="d-flex align-items-center gap-2 ms-auto">
          <button type="button"
                  class="btn btn-outline-secondary btn-sm"
                  data-grid-overlay-target="pointsToggleButton"
                  data-action="grid-overlay#togglePoints"
                  <%= 'disabled' unless has_points_preview %>
                  aria-label="Alternar imagem com cabecas marcadas">
            Points: Off
          </button>
          <button type="button"
                  class="btn btn-outline-secondary btn-sm"
                  data-grid-overlay-target="overlayToggleButton"
                  data-action="grid-overlay#toggleOverlay"
                  <%= 'disabled' unless has_saved_grid %>
                  aria-label="Ligar ou desligar grid no mosaico">
            Grid: On
          </button>
          <div class="btn-group" role="group" aria-label="Controles de zoom do mosaico">
            <button type="button"
                    class="btn btn-outline-secondary btn-sm"
                    data-action="image-zoom#zoomOut"
                    data-image-zoom-target="zoomOutButton"
                    aria-label="Reduzir zoom">-</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" disabled data-image-zoom-target="level">100%</button>
            <button type="button"
                    class="btn btn-outline-secondary btn-sm"
                    data-action="image-zoom#zoomIn"
                    data-image-zoom-target="zoomInButton"
                    aria-label="Aumentar zoom">+</button>
          </div>
        </div>
      </div>

       <div class="grid-overlay-preview border rounded p-2 bg-light-subtle mosaic-zoom-frame"
         tabindex="0"
         role="region"
         aria-label="Visualizacao ampliada do mosaico"
         data-image-zoom-target="frame"
         data-action="mousedown->image-zoom#startPan mousemove->image-zoom#pan mouseup->image-zoom#endPan mouseleave->image-zoom#endPan blur->image-zoom#resetView">
        <div class="mosaic-zoom-canvas" data-image-zoom-target="canvas">
          <img data-mosaic-progress-target="previewImage"
            data-grid-overlay-target="previewImage"
               src="<%= @latest_mosaic_preview_url %>"
               alt="Mosaico da pasta <%= @pasta_nome %>"
               class="img-fluid rounded"
               loading="lazy">
          <div class="grid-overlay-layer" data-grid-overlay-target="overlay"></div>
          <div class="grid-overlay-counts" data-grid-overlay-target="counts"></div>
        </div>
      </div>

      <%= form_with url: cut_mosaic_uploader_evento_path(@evento),
                    method: :post,
                    local: true,
                    class: 'mt-3',
                    data: {
                      controller: 'mosaic-cut-progress',
                      action: 'submit->mosaic-cut-progress#submit'
                    } do %>
        <%= hidden_field_tag :pasta, @pasta_param %>

        <h3 class="h6 mb-2">Seletor de Grade</h3>
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <span class="text-muted">Grade selecionada:</span>
            <span class="badge text-bg-success" data-grid-overlay-target="selectionLabel"><%= "#{selected_rows}x#{selected_cols}" %></span>
          </div>
        </div>

        <div class="d-flex flex-column flex-lg-row align-items-start gap-3 mt-3">
          <div class="grid-picker grid-picker-mosaic mt-0" data-action="mouseleave->grid-overlay#restoreSelection">
            <% (1..4).each do |row| %>
              <% (1..8).each do |col| %>
                <button type="button"
                        class="grid-picker-cell"
                        data-grid-overlay-target="cell"
                        data-row="<%= row %>"
                        data-col="<%= col %>"
                        data-action="mouseenter->grid-overlay#hoverCell click->grid-overlay#selectCell"
                        aria-label="Selecionar grade <%= row %> por <%= col %>">
                </button>
              <% end %>
            <% end %>
          </div>

          <div class="ms-lg-auto w-100" style="max-width: 280px;">
            <div class="border rounded p-3 bg-light-subtle">
              <h4 class="h6 mb-3">Resumo das imagens</h4>
              <dl class="row mb-0 small">
                <dt class="col-8 text-muted">Total na pasta</dt>
                <dd class="col-4 text-end fw-semibold mb-2"><%= @mosaic_total_images %></dd>

                <dt class="col-8 text-muted">Zenitais</dt>
                <dd class="col-4 text-end fw-semibold mb-2"><%= @mosaic_zenital_images %></dd>

                <dt class="col-8 text-muted">Selecionadas p/ mosaico</dt>
                <dd class="col-4 text-end fw-semibold mb-0"><%= @mosaic_selected_images %></dd>
              </dl>
            </div>
          </div>
        </div>

        <%= hidden_field_tag :rows, selected_rows, data: { grid_overlay_target: 'rowsInput', mosaic_cut_progress_target: 'rowsInput' } %>
        <%= hidden_field_tag :cols, selected_cols, data: { grid_overlay_target: 'colsInput', mosaic_cut_progress_target: 'colsInput' } %>

        <div class="mt-3">
          <%= button_tag 'Cortar',
                         type: 'submit',
                         class: 'btn btn-success',
                         data: {
                           mosaic_cut_progress_target: 'submit',
                           turbo_confirm: 'Deseja cortar o mosaico usando o grid selecionado? Os arquivos serao gerados apenas em pasta temporaria.'
                         } %>
        </div>

        <div class="mt-3 d-none" data-mosaic-cut-progress-target="progressWrapper" aria-live="polite">
          <div class="progress" role="progressbar" aria-label="Progresso do corte e contagem do mosaico">
            <div class="progress-bar progress-bar-striped progress-bar-animated" data-mosaic-cut-progress-target="progressBar" style="width: 0%;">0%</div>
          </div>
          <div class="small text-muted mt-2" data-mosaic-cut-progress-target="status">Aguardando inicio do corte.</div>
          <div class="small text-muted" data-mosaic-cut-progress-target="counts">Contados: 0 de 0.</div>
        </div>

        <div class="alert alert-danger mt-3 mb-0 d-none" data-mosaic-cut-progress-target="error"></div>
      <% end %>
    </div>
  </div>
</div>
