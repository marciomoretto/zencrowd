<h1>Upload de Imagens</h1>

<%= form_with url: admin_tiles_path, method: :post, local: true, html: { multipart: true, class: 'mb-4' } do |f| %>
  <div class="mb-3">
    <label for="images" class="form-label">Selecione os tiles</label>
    <input type="file" name="images[]" id="images" class="form-control" multiple accept="image/jpeg,image/png">
  </div>
  <p class="text-muted mb-3">O valor da tarefa é calculado automaticamente a partir da contagem estimada de cabeças.</p>
  <button type="submit" class="btn btn-primary">Enviar</button>
<% end %>

<%= link_to 'Voltar', admin_tiles_path, class: 'btn btn-secondary mt-3' %>

<% if flash[:notice] %>
  <div class="alert alert-success mt-3"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger mt-3"><%= flash[:alert] %></div>
<% end %>
