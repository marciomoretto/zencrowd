<h1>Tarefas de Revisão</h1>

<% if @tiles.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Tile</th>
        <th>Annotador</th>
        <th>Status</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @tiles.each do |tile| %>
        <tr>
          <td><%= tile.original_filename %></td>
          <td><%= tile.reserver&.name || '-' %></td>
          <td><%= tile.status %></td>
          <td>
            <% if tile.status == 'submitted' %>
              <%= button_to 'Iniciar Revisão', start_review_tile_path(tile), method: :post, class: 'btn btn-primary', form: { data: { turbo: false } } %>
            <% elsif tile.status == 'in_review' %>
              <%= button_to 'Aprovar', approve_tile_path(tile), method: :post, class: 'btn btn-success', form: { data: { turbo: false } } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>Nenhum tile para revisar.</p>
<% end %>
