<h1>Tarefas de Revisão</h1>

<% if @tiles.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>Tile</th>
        <th>Annotador</th>
        <th>Status</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @tiles.each do |tile| %>
        <tr>
          <td><%= tile.original_filename %></td>
          <td><%= tile.reserver&.name || '-' %></td>
          <td><%= tile.status %></td>
          <td>
            <% if %w[submitted in_review].include?(tile.status) %>
              <%= button_to 'Aprovar', approve_tile_path(tile), method: :post, class: 'btn btn-success', form: { data: { turbo: false } } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @tiles.respond_to?(:current_page) %>
    <div class="d-flex justify-content-center mt-3">
      <%= paginate @tiles %>
    </div>
  <% end %>
<% else %>
  <p>Nenhum tile para revisar.</p>
<% end %>
