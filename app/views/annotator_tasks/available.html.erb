<h1>Tiles Disponíveis para Anotação</h1>

<% if flash[:notice] %>
  <div class="alert alert-success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger"><%= flash[:alert] %></div>
<% end %>

<% if @tiles.any? %>
  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>ID</th>
        <th>Arquivo</th>
        <th>Valor da Tarefa</th>
        <th>Ação</th>
      </tr>
    </thead>
    <tbody>
      <% @tiles.each do |tile| %>
        <tr id="tile-row-<%= tile.id %>">
          <td><%= tile.id %></td>
          <td><%= tile.original_filename %></td>
          <td><%= number_with_precision(tile.task_value, precision: 2) %></td>
          <td>
            <%= button_to 'Reservar', reserve_tile_path(tile), method: :post, class: 'btn btn-primary btn-sm', data: { turbo_confirm: 'Deseja reservar este tile?' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="alert alert-info">Nenhum tile disponível para anotação no momento.</div>
<% end %>
