<h1>Imagens Disponíveis para Anotação</h1>

<% if flash[:notice] %>
  <div class="alert alert-success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger"><%= flash[:alert] %></div>
<% end %>

<% if @images.any? %>
  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>ID</th>
        <th>Arquivo</th>
        <th>Valor da Tarefa</th>
        <th>Ação</th>
      </tr>
    </thead>
    <tbody>
      <% @images.each do |image| %>
        <tr id="image-row-<%= image.id %>">
          <td><%= image.id %></td>
          <td><%= image.original_filename %></td>
          <td><%= number_with_precision(image.task_value, precision: 2) %></td>
          <td>
            <%= button_to 'Reservar', reserve_image_path(image), method: :post, class: 'btn btn-primary btn-sm', data: { turbo_confirm: 'Deseja reservar esta imagem?' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="alert alert-info">Nenhuma imagem disponível para anotação no momento.</div>
<% end %>
