<h1>Tarefas Disponíveis</h1>

<% if flash[:notice] %>
  <div class="alert alert-success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:warning] %>
  <div class="alert alert-warning"><%= flash[:warning] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger"><%= flash[:alert] %></div>
<% end %>

<%
sortable_header = lambda do |label, column|
  next_direction = (@sort == column && @direction == 'asc') ? 'desc' : 'asc'
  icon_class = if @sort == column
                 @direction == 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill'
               else
                 'bi-arrow-down-up'
               end

  link_to available_tiles_path(request.query_parameters.merge(sort: column, direction: next_direction)),
          class: 'text-decoration-none text-dark d-inline-flex align-items-center gap-1' do
    safe_join([
      content_tag(:span, label),
      content_tag(:i, nil, class: "bi #{icon_class} small text-secondary", aria: { hidden: true })
    ])
  end
end
%>

<%= form_with url: available_tiles_path, method: :get, local: true, class: 'row g-2 align-items-end mb-3' do %>
  <div class="col-md-4">
    <%= label_tag :status, 'Filtrar por status', class: 'form-label' %>
    <%= select_tag :status,
                   options_for_select([
                     ['Todos', ''],
                     ['Nova', 'available'],
                     ['Abandonada', 'abandoned']
                   ], @status_filter),
                   class: 'form-select' %>
  </div>
  <div class="col-md-4 d-flex gap-2">
    <%= hidden_field_tag :sort, @sort if @sort.present? %>
    <%= hidden_field_tag :direction, @direction if @direction.present? %>
    <%= submit_tag 'Aplicar filtro', class: 'btn btn-primary' %>
    <%= link_to 'Limpar', available_tiles_path, class: 'btn btn-outline-secondary' %>
  </div>
<% end %>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <% if @tiles.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Arquivo</th>
              <th><%= sortable_header.call('Valor da Tarefa', 'task_value') %></th>
              <th>Situação</th>
              <th>Ação</th>
            </tr>
          </thead>
          <tbody>
            <% @tiles.each do |tile| %>
              <% latest_annotation = tile.annotations.max_by(&:created_at) %>
              <% marked_points_count = latest_annotation&.annotation_points&.size.to_i %>
              <tr id="tile-row-<%= tile.id %>">
                <td><%= tile.id %></td>
                <td><%= link_to tile.original_filename, tile_path(tile), class: 'text-decoration-none' %></td>
                <td><%= number_to_currency(tile.task_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></td>
                <td>
                  <% if @task_is_new_by_tile_id[tile.id] %>
                    <span class="btn btn-outline-success btn-sm" role="status">Nova</span>
                  <% else %>
                    <span class="position-relative d-inline-block" role="status" aria-label="Abandonada com <%= marked_points_count %> pontos marcados">
                      <span class="btn btn-outline-warning btn-sm">Abandonada</span>
                      <span class="position-absolute bottom-0 start-100 translate-middle badge rounded-pill text-bg-secondary" title="Quantidade de pontos já marcados"><%= marked_points_count %></span>
                    </span>
                  <% end %>
                </td>
                <td>
                  <%= button_to 'Reservar', reserve_tile_path(tile), method: :post, class: 'btn btn-primary btn-sm', data: { turbo_confirm: 'Deseja reservar este tile?' } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="p-4">
        <div class="alert alert-info mb-0">Nenhum tile disponível para anotação no momento.</div>
      </div>
    <% end %>
  </div>
</div>
