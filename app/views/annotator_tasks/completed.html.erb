<% content_for :title, 'Minhas Tarefas' %>

<div class="d-flex justify-content-between align-items-center page-header">
  <div>
    <h1 class="page-title">Minhas Tarefas</h1>
    <p class="text-muted mb-0">Histórico das tarefas realizadas por você.</p>
  </div>
  <div class="d-flex flex-wrap justify-content-end gap-4">
    <div class="text-end">
      <p class="text-muted small mb-0">Total recebido</p>
      <p class="h5 mb-0"><%= number_to_currency(@paid_tasks_total_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></p>
    </div>
    <div class="text-end">
      <p class="text-muted small mb-0">Total a receber</p>
      <p class="h5 mb-0"><%= number_to_currency(@to_pay_tasks_total_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></p>
    </div>
  </div>
</div>

<%
sortable_header = lambda do |label, column|
  next_direction = (@completed_sort == column && @completed_direction == 'asc') ? 'desc' : 'asc'
  icon_class = if @completed_sort == column
                 @completed_direction == 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill'
               else
                 'bi-arrow-down-up'
               end

  link_to completed_tasks_path(request.query_parameters.merge(sort: column, direction: next_direction)),
          class: 'text-decoration-none text-dark d-inline-flex align-items-center gap-1' do
    safe_join([
      content_tag(:span, label),
      content_tag(:i, nil, class: "bi #{icon_class} small text-secondary", aria: { hidden: true })
    ])
  end
end
%>

<%
status_filter_options = [['Todos os status', '']] +
  @completed_status_options.map { |status| [human_tile_status(status), status] }
%>

<%= form_with url: completed_tasks_path, method: :get, local: true, class: 'row g-2 align-items-end mb-3' do %>
  <div class="col-md-4">
    <%= label_tag :status, 'Filtrar por status', class: 'form-label' %>
    <%= select_tag :status,
                   options_for_select(status_filter_options, @completed_status_filter),
                   class: 'form-select' %>
  </div>
  <div class="col-md-4 d-flex gap-2">
    <%= hidden_field_tag :sort, @completed_sort if @completed_sort.present? %>
    <%= hidden_field_tag :direction, @completed_direction if @completed_direction.present? %>
    <%= submit_tag 'Aplicar filtro', class: 'btn btn-primary' %>
    <%= link_to 'Limpar', completed_tasks_path, class: 'btn btn-outline-secondary' %>
  </div>
<% end %>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <% if @finalized_annotations.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th><%= sortable_header.call('Tarefa', 'task_id') %></th>
              <th>Arquivo</th>
              <th><%= sortable_header.call('Valor', 'task_value') %></th>
              <th><%= sortable_header.call('Total de Pontos', 'total_points') %></th>
              <th>Status</th>
              <th><%= sortable_header.call('Finalizada em', 'finalized_at') %></th>
            </tr>
          </thead>
          <tbody>
            <% if @reserved_tile_for_completed.present? %>
              <tr>
                <td>
                  <span><%= @reserved_tile_for_completed.id %></span>
                  <span class="badge text-bg-primary ms-2">Atual</span>
                </td>
                <td><%= link_to @reserved_tile_for_completed.original_filename, tile_path(@reserved_tile_for_completed), class: 'text-decoration-none' %></td>
                <td>
                  <% if @reserved_tile_for_completed.task_value.present? %>
                    <%= number_to_currency(@reserved_tile_for_completed.task_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td><%= @reserved_tile_for_completed.tile_point_set&.points&.size.to_i %></td>
                <td>
                  <span class="<%= tile_status_button_class('reserved') %>" role="button" aria-disabled="true">
                    <%= human_tile_status('reserved') %>
                  </span>
                </td>
                <td>-</td>
              </tr>
            <% end %>

            <% @finalized_annotations.each do |annotation| %>
              <% tile = annotation.image %>
              <% display_status = (tile.status == 'reserved' && annotation.review&.rejected?) ? 'rejected' : tile.status %>
              <tr>
                <td>
                  <span><%= tile.id %></span>
                  <% if @current_task_tile_id == tile.id %>
                    <span class="badge text-bg-primary ms-2">Atual</span>
                  <% end %>
                </td>
                <td><%= link_to tile.original_filename, tile_path(tile), class: 'text-decoration-none' %></td>
                <td>
                  <% if tile.task_value.present? %>
                    <%= number_to_currency(tile.task_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %>
                  <% else %>
                    -
                  <% end %>
                </td>
                <td><%= annotation.annotation_points.size %></td>
                <td>
                  <span class="<%= tile_status_button_class(display_status) %>" role="button" aria-disabled="true">
                    <%= human_tile_status(display_status) %>
                  </span>
                </td>
                <td><%= l(annotation.submitted_at || annotation.created_at, format: :short) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @finalized_annotations.respond_to?(:current_page) %>
        <div class="d-flex justify-content-center p-3 pb-0">
          <%= paginate @finalized_annotations %>
        </div>
      <% end %>
    <% else %>
      <div class="p-4">
        <div class="alert alert-info mb-0">Você ainda não finalizou nenhuma tarefa.</div>
      </div>
    <% end %>
  </div>
</div>
