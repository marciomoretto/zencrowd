<h1>Tarefa Atual</h1>

<% if flash[:notice] %>
  <div class="alert alert-success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:warning] %>
  <div class="alert alert-warning"><%= flash[:warning] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger"><%= flash[:alert] %></div>
<% end %>

<% if @tile %>
  <% preview_available = @tile.storage_path.present? && File.exist?(@tile.storage_path) %>
  <% preview_url = preview_available ? preview_tile_path(@tile) : nil %>


  <% if @tile.status == 'reserved' %>
    <% if defined?(ZenPlot) %>
      <style>
        body {
          overflow-y: auto !important;
          height: auto !important;
        }
      </style>

      <div class="card mb-4 zen-plot-card">
        <div class="card-header fw-semibold">Editor de Pontos (ZenPlot)</div>
        <div class="card-body p-0">
          <%= zen_plot_assets %>

          <main class="minimal-app"
                data-wpd-app
                data-wpd-default-image="<%= preview_url.presence || asset_path('images/teste.jpg') %>"
                data-wpd-submit-url="<%= zen_plot_points_tile_path(@tile, format: :json) %>"
                data-wpd-default-points="<%= zen_plot_points_tile_path(@tile, format: :json) %>">
            <div class="wpd-loading-curtain" data-wpd-loading-curtain>
              Loading application, please wait...
            </div>

            <div class="minimal-controls">
              <%= render "zen_plot/pages/point_color_picker" %>
              <%= render "zen_plot/pages/control_zoom" %>
              <%= render "zen_plot/pages/control_mode" %>
              <%= render "zen_plot/pages/points_count" %>
              <div class="control-group submit-group submit-group-end">
                <%= button_to 'Desistir',
                              give_up_tile_path(@tile),
                              method: :post,
                              form: { class: 'd-inline m-0' },
                              class: 'submit-button give-up-button-outline-danger',
                              data: { turbo_confirm: 'Tem certeza que deseja desistir desta tarefa? O tile voltará para disponível.' } %>
                <button type="button" data-wpd-submit class="submit-button save-button-outline-primary">Salvar</button>
                <button type="button"
                        id="zen-plot-finalize-btn"
                        class="submit-button submit-finish-button"
                        data-finalize-url="<%= finalize_zen_plot_points_tile_path(@tile, format: :json) %>"
                        data-finalized="<%= @tile.tile_point_set&.finalized? ? 'true' : 'false' %>"
                        <%= @tile.tile_point_set&.finalized? ? 'disabled' : nil %>>
                  <%= @tile.tile_point_set&.finalized? ? 'Enviado' : 'Enviar' %>
                </button>
              </div>
            </div>

            <%= render "zen_plot/pages/workspace", show_zoom_panel: true %>
          </main>
        </div>
      </div>

      <div id="zen-plot-feedback" class="alert alert-secondary d-none" role="status" aria-live="polite"></div>

      <script>
        (function() {
          function setupZenPlotFeedback() {
            var root = document.querySelector('[data-wpd-app]');
            var feedback = document.getElementById('zen-plot-feedback');
            var finalizeBtn = document.getElementById('zen-plot-finalize-btn');

            if (!root || !feedback) {
              return;
            }

            if (!root.__wpdMinimalApp) {
              if (window.wpd) {
                if (typeof window.wpd.mountMinimalApp === 'function') {
                  window.wpd.mountMinimalApp(root);
                } else if (typeof window.wpd.initMinimalApps === 'function') {
                  window.wpd.initMinimalApps();
                }
              }

              if (!root.__wpdMinimalApp) {
                var retryCount = Number(root.dataset.wpdInitRetryCount || '0');
                if (retryCount < 25) {
                  root.dataset.wpdInitRetryCount = String(retryCount + 1);
                  setTimeout(setupZenPlotFeedback, 80);
                  return;
                }

                feedback.classList.remove('d-none', 'alert-success', 'alert-secondary');
                feedback.classList.add('alert-warning');
                feedback.textContent = 'Não foi possível iniciar o editor automaticamente. Atualize a página.';
                return;
              }

              root.dataset.wpdInitRetryCount = '0';
            }

            function positionZoomPanelWithinContainer() {
              var zoomPanel = root.querySelector('.zoom-panel');
              if (!zoomPanel) {
                return;
              }

              if (zoomPanel.dataset.initialPlacementDone === 'true') {
                return;
              }

              if (window.getComputedStyle(zoomPanel).position !== 'fixed') {
                return;
              }

              var rootRect = root.getBoundingClientRect();
              var panelWidth = zoomPanel.offsetWidth || 220;
              var viewportPadding = 12;
              var insideTopOffset = 150;
              var insideRightPadding = 50;

              var top = Math.round(rootRect.top + insideTopOffset);
              var left = Math.round(rootRect.right - panelWidth - insideRightPadding);

              top = Math.max(viewportPadding, Math.min(top, window.innerHeight - 140));
              left = Math.max(viewportPadding, Math.min(left, window.innerWidth - panelWidth - viewportPadding));

              zoomPanel.style.top = top + 'px';
              zoomPanel.style.left = left + 'px';
              zoomPanel.style.right = 'auto';
              zoomPanel.style.bottom = 'auto';
              zoomPanel.dataset.initialPlacementDone = 'true';
            }

            requestAnimationFrame(positionZoomPanelWithinContainer);
            setTimeout(positionZoomPanelWithinContainer, 120);

            if (root.dataset.zenPlotFeedbackBound === 'true') {
              return;
            }

            root.dataset.zenPlotFeedbackBound = 'true';

            function updateFeedback(message, level) {
              feedback.classList.remove('d-none', 'alert-success', 'alert-warning', 'alert-secondary');
              feedback.classList.add('alert-' + level);
              feedback.textContent = message;
            }

            function buildPayloadFromApp() {
              var app = root.__wpdMinimalApp;
              if (!app || !Array.isArray(app.points)) {
                return null;
              }

              return {
                axis: 'image',
                points: app.points.map(function(point, index) {
                  return {
                    id: index + 1,
                    x: Number(point.x.toFixed(2)),
                    y: Number(point.y.toFixed(2))
                  };
                })
              };
            }

            function setFinalizeButtonState(state) {
              if (!finalizeBtn) {
                return;
              }

              if (state === 'finalized') {
                finalizeBtn.disabled = true;
                finalizeBtn.dataset.finalized = 'true';
                finalizeBtn.textContent = 'Enviado';
                return;
              }

              if (state === 'saving') {
                finalizeBtn.disabled = true;
                finalizeBtn.textContent = 'Salvando...';
                return;
              }

              if (state === 'sending') {
                finalizeBtn.disabled = true;
                finalizeBtn.textContent = 'Enviando...';
                return;
              }

              finalizeBtn.disabled = false;
              finalizeBtn.textContent = 'Enviar';
            }

            function postJson(url, payload) {
              var headers = {
                'Accept': 'application/json',
                'Content-Type': 'application/json'
              };
              var csrfMeta = document.querySelector('meta[name="csrf-token"]');
              if (csrfMeta) {
                headers['X-CSRF-Token'] = csrfMeta.content;
              }

              return window.fetch(url, {
                method: 'POST',
                credentials: 'same-origin',
                headers: headers,
                body: JSON.stringify(payload)
              }).then(function(response) {
                return response.json().then(function(body) {
                  return { ok: response.ok, body: body };
                }).catch(function() {
                  return { ok: response.ok, body: null };
                });
              });
            }

            root.addEventListener('wpd:points:loaded', function(event) {
              var pointsCount = event.detail && Number(event.detail.points_count) ? Number(event.detail.points_count) : 0;
              if (pointsCount > 0) {
                updateFeedback('Foram carregados ' + pointsCount + ' pontos salvos para este tile.', 'secondary');
              }
            });

            root.addEventListener('wpd:submit:stored', function(event) {
              var pointsCount = event.detail && Number(event.detail.points_count) ? Number(event.detail.points_count) : null;
              if (pointsCount === null) {
                updateFeedback('Pontos salvos com sucesso.', 'success');
                return;
              }

              updateFeedback('Pontos salvos com sucesso (' + pointsCount + ' pontos).', 'success');
            });

            root.addEventListener('wpd:submit:storage-error', function(event) {
              var errors = event.detail && Array.isArray(event.detail.errors) ? event.detail.errors.join(', ') : 'falha ao salvar pontos';
              updateFeedback('Não foi possível salvar os pontos: ' + errors, 'warning');
            });

            if (finalizeBtn) {
              if (finalizeBtn.dataset.finalized === 'true') {
                setFinalizeButtonState('finalized');
              }

              finalizeBtn.addEventListener('click', function() {
                if (finalizeBtn.dataset.finalized === 'true') {
                  return;
                }

                var app = root.__wpdMinimalApp;
                if (!app || typeof app.submit !== 'function') {
                  updateFeedback('Aplicação de pontos ainda não está pronta para envio.', 'warning');
                  return;
                }

                var finalizeUrl = finalizeBtn.dataset.finalizeUrl;
                if (!finalizeUrl) {
                  updateFeedback('Endpoint de envio final não configurado.', 'warning');
                  return;
                }

                setFinalizeButtonState('saving');

                var done = false;

                function cleanup() {
                  root.removeEventListener('wpd:submit:stored', onStored);
                  root.removeEventListener('wpd:submit:storage-error', onSaveError);
                }

                function onSaveError(event) {
                  if (done) {
                    return;
                  }

                  done = true;
                  cleanup();
                  setFinalizeButtonState('idle');

                  var errors = event.detail && Array.isArray(event.detail.errors) ? event.detail.errors.join(', ') : 'falha ao salvar pontos';
                  updateFeedback('Não foi possível enviar: erro ao salvar (' + errors + ').', 'warning');
                }

                function onStored() {
                  if (done) {
                    return;
                  }

                  done = true;
                  cleanup();

                  var payload = app.lastSubmittedPayload || buildPayloadFromApp();
                  if (!payload) {
                    setFinalizeButtonState('idle');
                    updateFeedback('Não foi possível montar o payload de pontos para finalizar.', 'warning');
                    return;
                  }

                  setFinalizeButtonState('sending');

                  postJson(finalizeUrl, payload).then(function(result) {
                    if (!result.ok) {
                      var errors = result.body && Array.isArray(result.body.errors) ? result.body.errors.join(', ') : 'erro desconhecido';
                      setFinalizeButtonState('idle');
                      updateFeedback('Pontos salvos, mas não foi possível finalizar: ' + errors, 'warning');
                      return;
                    }

                    setFinalizeButtonState('finalized');
                    updateFeedback('Pontos salvos e tarefa enviada como finalizada.', 'success');
                  }).catch(function(error) {
                    setFinalizeButtonState('idle');
                    updateFeedback('Pontos salvos, mas a finalização falhou: ' + error.message, 'warning');
                  });
                }

                root.addEventListener('wpd:submit:stored', onStored);
                root.addEventListener('wpd:submit:storage-error', onSaveError);
                app.submit();
              });
            }
          }

          setupZenPlotFeedback();
          document.addEventListener('DOMContentLoaded', setupZenPlotFeedback);
          document.addEventListener('turbo:load', setupZenPlotFeedback);
        })();
      </script>
    <% else %>
      <div class="alert alert-warning">
        ZenPlot não está disponível nesta instalação.
      </div>
    <% end %>

  <% end %>
<% else %>
  <div class="alert alert-info">Nenhuma tarefa reservada.<br>
    <%= link_to 'Ver tarefas disponíveis', available_tiles_path, class: 'btn btn-primary mt-2' %>
  </div>
<% end %>
