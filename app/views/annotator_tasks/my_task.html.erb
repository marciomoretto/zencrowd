<h1>Meu Tile Reservado</h1>

<% if flash[:notice] %>
  <div class="alert alert-success"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger"><%= flash[:alert] %></div>
<% end %>

<% if @tile %>
  <table class="table table-bordered">
    <tr>
      <th>ID</th>
      <td><%= @tile.id %></td>
    </tr>
    <tr>
      <th>Arquivo</th>
      <td><%= @tile.original_filename %></td>
    </tr>
    <tr>
      <th>Valor da Tarefa</th>
      <td><%= number_to_currency(@tile.task_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u %n') %></td>
    </tr>
    <tr>
      <th>Preview</th>
      <td>
        <% if @tile.storage_path.present? && File.exist?(@tile.storage_path) %>
          <%= image_tag "/uploads/#{File.basename(@tile.storage_path)}", class: 'img-thumbnail', style: 'max-width: 300px;' %>
        <% else %>
          <span class="text-muted">Sem preview disponível</span>
        <% end %>
      </td>
    </tr>
  </table>

  <% if @tile.status == 'reserved' %>
    <h3 class="mt-4">Submeter Anotação</h3>
    <%= form_with url: submit_tile_path(@tile), method: :post, local: true, html: { multipart: true, class: 'needs-validation' } do |f| %>
      <div class="mb-3">
        <%= f.label :projeto_tar, 'Arquivo do Projeto (.tar)', class: 'form-label' %>
        <%= f.file_field :projeto_tar, class: 'form-control', required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :dados_csv, 'Arquivo de Dados (.csv)', class: 'form-label' %>
        <%= f.file_field :dados_csv, class: 'form-control', required: true %>
      </div>
      <div class="mb-3">
        <%= f.label :config_json, 'Configuração (opcional, .json)', class: 'form-label' %>
        <%= f.file_field :config_json, class: 'form-control' %>
      </div>
      <div class="d-grid gap-2">
        <%= f.submit 'Submeter', class: 'btn btn-success btn-lg' %>
      </div>
    <% end %>
  <% end %>
<% else %>
  <div class="alert alert-info">Nenhuma tarefa reservada.<br>
    <%= link_to 'Ver tiles disponíveis', available_tiles_path, class: 'btn btn-primary mt-2' %>
  </div>
<% end %>
