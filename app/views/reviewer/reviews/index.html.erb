<h1>Tarefas de Revisão</h1>

<%
sortable_header = lambda do |label, column|
  next_direction = (@sort == column && @direction == 'asc') ? 'desc' : 'asc'
  icon_class = if @sort == column
                 @direction == 'asc' ? 'bi-caret-up-fill' : 'bi-caret-down-fill'
               else
                 'bi-arrow-down-up'
               end

  link_to reviewer_reviews_path(request.query_parameters.merge(sort: column, direction: next_direction)),
          class: 'text-decoration-none text-dark d-inline-flex align-items-center gap-1' do
    safe_join([
      content_tag(:span, label),
      content_tag(:i, nil, class: "bi #{icon_class} small text-secondary", aria: { hidden: true })
    ])
  end
end
%>

<%
status_options = [
  ['Todos os status', ''],
  ['Reservado', 'reserved'],
  ['Submetido', 'submitted'],
  ['Em revisão', 'in_review'],
  ['Aprovado', 'approved'],
  ['Reprovado', 'rejected'],
  ['Pago', 'paid']
]

annotator_options = [['Todos os anotadores', '']] + @annotators.map { |annotator| [annotator.name, annotator.id] }
%>

<%= form_with url: reviewer_reviews_path, method: :get, local: true, class: 'row g-2 align-items-end mb-3' do %>
  <div class="col-md-4">
    <%= label_tag :status, 'Filtrar por status', class: 'form-label' %>
    <%= select_tag :status, options_for_select(status_options, @status_filter), class: 'form-select' %>
  </div>
  <div class="col-md-4">
    <%= label_tag :annotator_id, 'Filtrar por anotador', class: 'form-label' %>
    <%= select_tag :annotator_id, options_for_select(annotator_options, @annotator_filter), class: 'form-select' %>
  </div>
  <div class="col-md-4 d-flex gap-2">
    <%= submit_tag 'Aplicar filtros', class: 'btn btn-primary' %>
    <%= link_to 'Limpar', reviewer_reviews_path, class: 'btn btn-outline-secondary' %>
  </div>
<% end %>

<% if @tiles.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Arquivo</th>
        <th>Status</th>
        <th><%= sortable_header.call('Qtd. Estimada', 'estimated_count') %></th>
        <th><%= sortable_header.call('Qtd. Marcada', 'marked_count') %></th>
        <th><%= sortable_header.call('Progresso', 'progress') %></th>
        <th>Anotador</th>
      </tr>
    </thead>
    <tbody>
      <% @tiles.each do |tile| %>
        <% latest_annotation = tile.annotations.max_by(&:created_at) %>
        <% latest_review = latest_annotation&.review %>
        <% reserved_after_rejection = tile.status == 'reserved' && latest_review&.rejected? %>
        <% marked_points_count = latest_annotation&.annotation_points&.size.to_i %>
        <% percentage = if tile.head_count.present? && tile.head_count.positive?
                          (marked_points_count.to_f / tile.head_count) * 100
                        end %>
        <% progress_icon_class = nil %>
        <% progress_color_class = nil %>
        <% progress_label = nil %>
        <% if percentage.present? %>
          <% if percentage > 90 %>
            <% progress_icon_class = 'bi-check-circle-fill' %>
            <% progress_color_class = 'text-success' %>
            <% progress_label = 'Acima do esperado' %>
          <% elsif percentage >= 75 %>
            <% progress_icon_class = 'bi-exclamation-triangle-fill' %>
            <% progress_color_class = 'text-warning' %>
            <% progress_label = 'Progresso intermediário' %>
          <% else %>
            <% progress_icon_class = 'bi-x-circle-fill' %>
            <% progress_color_class = 'text-danger' %>
            <% progress_label = 'Abaixo do esperado' %>
          <% end %>
        <% end %>
        <tr>
          <td><%= tile.id %></td>
          <td><%= link_to tile.original_filename, reviewer_review_path(tile), class: 'text-decoration-none' %></td>
          <td>
            <% if reserved_after_rejection %>
              <span class="btn btn-sm btn-outline-warning py-0 px-2" title="Reprovado e devolvido ao anotador; fica reservado ate expirar.">Reprovado (com anotador)</span>
            <% elsif tile.status == 'reserved' %>
              <span class="btn btn-sm btn-outline-warning py-0 px-2">Reservado</span>
            <% elsif tile.status == 'submitted' %>
              <span class="btn btn-sm btn-outline-primary py-0 px-2">Submetido</span>
            <% elsif tile.status == 'in_review' %>
              <span class="btn btn-sm btn-outline-primary py-0 px-2">Em revisão</span>
            <% elsif tile.status == 'approved' %>
              <span class="btn btn-sm btn-outline-success py-0 px-2">Aprovado</span>
            <% elsif tile.status == 'rejected' %>
              <span class="btn btn-sm btn-outline-danger py-0 px-2">Reprovado</span>
            <% elsif tile.status == 'paid' %>
              <span class="btn btn-sm btn-success py-0 px-2">Pago</span>
            <% else %>
              <span class="badge text-bg-secondary"><%= tile.status.humanize %></span>
            <% end %>
          </td>
          <td><%= tile.head_count.present? ? tile.head_count : '-' %></td>
          <td><%= marked_points_count %></td>
          <td>
            <% if percentage.present? %>
              <i
                class="bi <%= progress_icon_class %> <%= progress_color_class %> fs-5"
                role="img"
                aria-label="<%= progress_label %>"
                title="<%= "#{progress_label} #{format('%.0f%%', percentage)}" %>"></i>
            <% else %>
              -
            <% end %>
          </td>
          <td><%= tile.reserver&.name || '-' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if !@tiles.any? %>
  <p>Nenhum tile para revisar.</p>
<% end %>