<h1>Tarefas de Revisão</h1>

<% if @images.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Arquivo</th>
        <th>Status</th>
        <th>Anotador</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @images.each do |image| %>
        <tr>
          <td><%= image.id %></td>
          <td><%= image.original_filename %></td>
          <td><%= image.status %></td>
          <td><%= image.reserver&.name || '-' %></td>
          <td>
            <% if image.status == 'submitted' %>
              <%= button_to 'Iniciar Revisão', start_review_image_path(image), method: :post, class: 'btn btn-primary btn-sm', form: { data: { turbo: false } } %>
            <% elsif image.status == 'in_review' %>
              <%= link_to 'Revisar', reviewer_review_path(image), class: 'btn btn-primary btn-sm' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if !@images.any? %>
  <p>Nenhuma imagem para revisar.</p>
<% end %>