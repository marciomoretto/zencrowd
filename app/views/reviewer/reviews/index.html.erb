<h1>Tarefas de Revisão</h1>

<% if @tiles.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Arquivo</th>
        <th>Status</th>
        <th>Anotador</th>
        <th>Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @tiles.each do |tile| %>
        <tr>
          <td><%= tile.id %></td>
          <td><%= tile.original_filename %></td>
          <td><%= tile.status %></td>
          <td><%= tile.reserver&.name || '-' %></td>
          <td>
            <% if tile.status == 'submitted' %>
              <%= button_to 'Iniciar Revisão', start_review_tile_path(tile), method: :post, class: 'btn btn-primary btn-sm', form: { data: { turbo: false } } %>
            <% elsif tile.status == 'in_review' %>
              <%= link_to 'Revisar', reviewer_review_path(tile), class: 'btn btn-primary btn-sm' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if !@tiles.any? %>
  <p>Nenhum tile para revisar.</p>
<% end %>