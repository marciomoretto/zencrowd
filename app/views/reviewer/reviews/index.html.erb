<h1>Tarefas de Revisão</h1>

<% if @tiles.any? %>
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Arquivo</th>
        <th>Status</th>
        <th>Anotador</th>
      </tr>
    </thead>
    <tbody>
      <% @tiles.each do |tile| %>
        <tr>
          <td><%= tile.id %></td>
          <td><%= link_to tile.original_filename, reviewer_review_path(tile), class: 'text-decoration-none' %></td>
          <td>
            <% if tile.status == 'submitted' %>
              <span class="badge text-bg-warning text-dark">Submetido</span>
            <% elsif tile.status == 'in_review' %>
              <span class="badge text-bg-primary">Em revisão</span>
            <% else %>
              <span class="badge text-bg-secondary"><%= tile.status.humanize %></span>
            <% end %>
          </td>
          <td><%= tile.reserver&.name || '-' %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if !@tiles.any? %>
  <p>Nenhum tile para revisar.</p>
<% end %>