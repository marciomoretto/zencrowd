<h1>Revisão do Tile <%= @tile.id %></h1>

<div class="row">
  <div class="col-md-6">
    <h4>Arquivo</h4>
    <p><%= @tile.original_filename %></p>
    <h4>Status</h4>
    <p><%= @tile.status %></p>
    <h4>Anotador</h4>
    <p><%= @tile.reserver&.name || '-' %></p>
    <h4>Tile</h4>
    <% if @tile.storage_path.present? && File.exist?(@tile.storage_path) %>
      <%= image_tag "/uploads/#{File.basename(@tile.storage_path)}", class: 'img-thumbnail', style: 'max-width: 300px;' %>
    <% else %>
      <span class="text-muted">Sem preview disponível</span>
    <% end %>
  </div>
  <div class="col-md-6">
    <h4>Anotação</h4>
    <% if @annotation %>
      <p>ID: <%= @annotation.id %></p>
      <h5>Pontos Anotados</h5>
      <% if @points&.any? %>
        <ul>
          <% @points.each do |point| %>
            <li>(<%= point.x %>, <%= point.y %>)</li>
          <% end %>
        </ul>
      <% else %>
        <p>Nenhum ponto anotado.</p>
      <% end %>
    <% else %>
      <p>Nenhuma anotação disponível.</p>
    <% end %>
    <div class="mt-4">
      <% if %w[submitted in_review].include?(@tile.status) %>
        <div class="d-flex gap-2">
          <%= button_to 'Aprovar', approve_tile_path(@tile), method: :post, class: 'btn btn-success', form: { class: 'm-0', data: { turbo: false } } %>
          <%= button_to 'Reprovar', reject_tile_path(@tile), method: :post, class: 'btn btn-danger', form: { class: 'm-0', data: { turbo: false } } %>
        </div>
      <% end %>
    </div>
  </div>
</div>