<h1>Revisão da Imagem <%= @image.id %></h1>

<div class="row">
  <div class="col-md-6">
    <h4>Arquivo</h4>
    <p><%= @image.original_filename %></p>
    <h4>Status</h4>
    <p><%= @image.status %></p>
    <h4>Anotador</h4>
    <p><%= @image.reserver&.name || '-' %></p>
    <h4>Imagem</h4>
    <% if @image.storage_path.present? && File.exist?(@image.storage_path) %>
      <%= image_tag "/uploads/#{File.basename(@image.storage_path)}", class: 'img-thumbnail', style: 'max-width: 300px;' %>
    <% else %>
      <span class="text-muted">Sem preview disponível</span>
    <% end %>
  </div>
  <div class="col-md-6">
    <h4>Anotação</h4>
    <% if @annotation %>
      <p>ID: <%= @annotation.id %></p>
      <h5>Pontos Anotados</h5>
      <% if @points&.any? %>
        <ul>
          <% @points.each do |point| %>
            <li>(<%= point.x %>, <%= point.y %>)</li>
          <% end %>
        </ul>
      <% else %>
        <p>Nenhum ponto anotado.</p>
      <% end %>
    <% else %>
      <p>Nenhuma anotação disponível.</p>
    <% end %>
    <div class="mt-4">
      <% if @image.status == 'in_review' %>
        <%= button_to 'Aprovar', approve_image_path(@image), method: :post, class: 'btn btn-success', form: { data: { turbo: false } } %>
        <%= button_to 'Reprovar', reject_image_path(@image), method: :post, class: 'btn btn-danger', form: { data: { turbo: false } } %>
      <% end %>
      <%= link_to 'Voltar', reviewer_reviews_path, class: 'btn btn-secondary' %>

      <div class="mt-3">
        <h5>DEBUG params:</h5>
        <%= debug(params) %>
        <h5>DEBUG current_user:</h5>
        <%= debug(current_user) %>
      </div>
    </div>
  </div>
</div>