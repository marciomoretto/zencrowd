<h1>Revisão do Tile <%= @tile.id %></h1>

<div class="row">
  <div class="col-md-7">
    <h4>Tile e Marcações</h4>
    <% preview_available = @tile.storage_path.present? && File.exist?(@tile.storage_path) %>
    <% if preview_available && defined?(ZenPlot) %>
      <%= zen_plot_assets %>

      <style>
        .reviewer-zoom-controls {
          display: flex;
          justify-content: flex-end;
          align-items: center;
          gap: 0.5rem;
          margin-bottom: 0.75rem;
        }

        .reviewer-zoom-controls .control-group {
          margin-bottom: 0;
        }

        .reviewer-zoom-controls .btn {
          width: 2.25rem;
          height: 2.25rem;
          padding: 0;
          display: inline-flex;
          align-items: center;
          justify-content: center;
        }

        .reviewer-zoom-controls .btn i {
          pointer-events: none;
        }

        .reviewer-zoom-label {
          font-size: 0.9rem;
          color: #6c757d;
          margin-bottom: 0;
        }

        .reviewer-zoom-icon {
          width: 18px;
          height: 18px;
          display: block;
        }

        .reviewer-action-buttons .btn {
          min-height: 2.5rem;
          line-height: 1.2;
          display: inline-flex;
          align-items: center;
          justify-content: center;
        }
      </style>

      <main class="minimal-app reviewer-plot-readonly"
            data-wpd-app
            data-wpd-default-image="<%= preview_tile_path(@tile) %>"
            data-wpd-default-points="<%= zen_plot_points_tile_path(@tile, format: :json) %>">
        <div class="wpd-loading-curtain" data-wpd-loading-curtain>
          Carregando plot...
        </div>

        <div class="minimal-controls reviewer-zoom-controls">
          <%= render "zen_plot/pages/control_zoom" %>
        </div>

        <%= render "zen_plot/pages/workspace", show_zoom_panel: false %>
      </main>

      <script>
        (function() {
          function mountReviewerReadOnlyPlot() {
            var root = document.querySelector('[data-wpd-app]');
            if (!root) {
              return;
            }

            if (window.wpd) {
              if (!root.__wpdMinimalApp && typeof window.wpd.mountMinimalApp === 'function') {
                window.wpd.mountMinimalApp(root);
              } else if (!root.__wpdMinimalApp && typeof window.wpd.initMinimalApps === 'function') {
                window.wpd.initMinimalApps();
              }
            }

            if (!root.__wpdMinimalApp) {
              var retryCount = Number(root.dataset.wpdInitRetryCount || '0');
              if (retryCount < 25) {
                root.dataset.wpdInitRetryCount = String(retryCount + 1);
                setTimeout(mountReviewerReadOnlyPlot, 80);
              }
              return;
            }

            if (root.dataset.wpdReadOnlyBound === 'true') {
              return;
            }

            root.dataset.wpdReadOnlyBound = 'true';

            function setupNativeZoomIcons() {
              var zoomButtons = root.querySelectorAll('.reviewer-zoom-controls button, .reviewer-zoom-controls .btn');
              if (!zoomButtons || zoomButtons.length < 2) {
                var zoomRetryCount = Number(root.dataset.wpdZoomRetryCount || '0');
                if (zoomRetryCount < 20) {
                  root.dataset.wpdZoomRetryCount = String(zoomRetryCount + 1);
                  setTimeout(setupNativeZoomIcons, 80);
                }
                return;
              }

              var zoomOutButton = zoomButtons[0];
              var zoomInButton = zoomButtons[1];

              zoomOutButton.innerHTML = '<svg class="reviewer-zoom-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="16.65" y1="16.65" x2="21" y2="21"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>';
              zoomOutButton.setAttribute('title', 'Zoom out');
              zoomOutButton.setAttribute('aria-label', 'Zoom out');

              zoomInButton.innerHTML = '<svg class="reviewer-zoom-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="16.65" y1="16.65" x2="21" y2="21"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>';
              zoomInButton.setAttribute('title', 'Zoom in');
              zoomInButton.setAttribute('aria-label', 'Zoom in');
            }

            setupNativeZoomIcons();

            // Mantem zoom (ex.: roda do mouse), mas bloqueia criacao/remocao de pontos.
            var blockedEvents = ['mousedown', 'mouseup', 'click', 'dblclick', 'contextmenu', 'touchstart', 'touchend'];

            blockedEvents.forEach(function(eventName) {
              root.addEventListener(eventName, function(event) {
                if (event.target && event.target.closest('.reviewer-zoom-controls')) {
                  return;
                }

                event.preventDefault();
                event.stopPropagation();
              }, true);
            });

            root.addEventListener('keydown', function(event) {
              if (event.key === 'Delete' || event.key === 'Backspace') {
                event.preventDefault();
                event.stopPropagation();
              }
            }, true);
          }

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', mountReviewerReadOnlyPlot, { once: true });
          } else {
            mountReviewerReadOnlyPlot();
          }
        })();
      </script>
    <% elsif preview_available %>
      <%= image_tag preview_tile_path(@tile), class: 'img-thumbnail', style: 'max-width: 100%; max-height: 520px;' %>
    <% else %>
      <span class="text-muted">Sem preview disponível</span>
    <% end %>

    <div class="mt-3">
      <% if @points&.any? %>
        <h5>Pontos anotados</h5>
        <ul class="mb-0">
          <% @points.each do |point| %>
            <li>(<%= point.x %>, <%= point.y %>)</li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-muted mb-0">Nenhum ponto anotado.</p>
      <% end %>
    </div>
  </div>
  <div class="col-md-5">
    <% original_image = @tile.imagens.first %>
    <h4>Resumo da Revisão</h4>
    <p><strong>ID:</strong> <%= @tile.id %></p>
    <p><strong>Arquivo:</strong> <%= @tile.original_filename %></p>
    <p>
      <strong>Arquivo original:</strong>
      <% if original_image&.arquivo&.attached? %>
        <%= link_to original_image.arquivo.filename.to_s,
                    imagem_path(original_image),
                    class: 'text-decoration-none' %>
      <% else %>
        -
      <% end %>
    </p>
    <p><strong>Qtd. de pontos marcados:</strong> <%= @points&.size.to_i %></p>
    <p><strong>Qtd. estimada de cabeças:</strong> <%= @tile.head_count.present? ? @tile.head_count : '-' %></p>

    <div class="mt-4">
      <% if %w[submitted in_review].include?(@tile.status) %>
        <div class="d-flex gap-2 align-items-stretch reviewer-action-buttons">
          <%= button_to 'Aprovar',
                        approve_tile_path(@tile),
                        method: :post,
                        class: 'btn btn-success py-2',
                        form: { class: 'm-0', data: { turbo: false } } %>
          <%= button_to 'Reprovar',
                        reject_tile_path(@tile),
                        method: :post,
                        class: 'btn btn-danger py-2',
                        form: { class: 'm-0', data: { turbo: false } } %>
        </div>
      <% end %>
    </div>
  </div>
</div>