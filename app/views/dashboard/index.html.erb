<% content_for :title, 'Dashboard' %>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
  <div>
    <h1 class="h3 mb-1">Dashboard</h1>
  </div>
</div>

<% quick_links = navigation_links_for(current_user).reject { |item| item[:path] == dashboard_path } %>

<div class="row g-3 mb-4">
  <% quick_links.each do |item| %>
    <div class="col-md-6 col-xl-4">
      <%= link_to item[:path], class: 'card h-100 text-decoration-none border-0 shadow-sm' do %>
        <div class="card-body d-flex align-items-center">
          <div class="me-3 text-primary" style="font-size: 1.5rem;">
            <i class="bi <%= item[:icon] %>"></i>
          </div>
          <div>
            <h2 class="h6 mb-1 text-dark"><%= item[:label] %></h2>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if current_user.admin? %>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted">Total de tiles aprovados</div>
          <div class="h3 mb-0"><%= @approved_tiles_total %></div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted">Total de cabeças contadas</div>
          <div class="h3 mb-0"><%= number_with_delimiter(@counted_heads_total) %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h6 mb-0">Execução do orçamento</h2>
        <span class="small text-muted">
          Comprometido:
          <strong><%= number_to_currency(@budget_committed, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></strong>
          (<%= number_with_precision(@committed_percentage, precision: 1) %>%)
        </span>
      </div>

      <div class="progress" role="progressbar" aria-label="Execução do orçamento" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= [@committed_percentage, 100].min %>">
        <div class="progress-bar bg-success"
             style="width: <%= number_with_precision(@paid_percentage, precision: 2) %>%;"
             aria-label="Pago"></div>
        <div class="progress-bar bg-warning text-dark"
             style="width: <%= number_with_precision(@to_pay_percentage, precision: 2) %>%;"
             aria-label="A pagar"></div>
      </div>

      <div class="d-flex flex-wrap gap-3 mt-2 small">
        <span><span class="badge text-bg-success">Pago</span> <%= number_to_currency(@total_paid, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></span>
        <span><span class="badge text-bg-warning">A pagar</span> <%= number_to_currency(@total_to_pay, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></span>
        <span><span class="badge text-bg-light">Restante</span> <%= number_to_currency(@budget_remaining, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></span>
      </div>

      <% if @budget_limit.zero? %>
        <p class="small text-muted mt-2 mb-0">Defina o orçamento nas configurações para habilitar a barra proporcional.</p>
      <% elsif @over_budget_amount.positive? %>
        <div class="alert alert-danger mt-2 mb-0 py-2">
          Excedente sobre orçamento: <strong><%= number_to_currency(@over_budget_amount, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></strong>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h6 mb-0">Progresso</h2>
        <span class="small text-muted">
          Total:
          <strong><%= @tracked_tiles_total %></strong>
        </span>
      </div>

      <div class="progress mb-3"
           role="progressbar"
           aria-label="Progresso"
           aria-valuemin="0"
           aria-valuemax="100"
           aria-valuenow="100">
        <div class="progress-bar"
             style="background-color: #14532d; width: <%= number_with_precision(@tile_status_percentages['paid'], precision: 2) %>%;"
             aria-label="Pago"></div>
         <div class="progress-bar"
           style="background-color: #9dbb4a; width: <%= number_with_precision(@tile_status_percentages['payment_requested'], precision: 2) %>%;"
           aria-label="Pagamento solicitado"></div>
         <div class="progress-bar"
           style="background-color: #4caf50; width: <%= number_with_precision(@tile_status_percentages['approved'], precision: 2) %>%;"
           aria-label="Aprovado"></div>
         <div class="progress-bar"
           style="background-color: #4f83cc; width: <%= number_with_precision(@tile_status_percentages['in_review'], precision: 2) %>%;"
           aria-label="Em revisão"></div>
         <div class="progress-bar"
           style="background-color: #ffd54f; width: <%= number_with_precision(@tile_status_percentages['reserved'], precision: 2) %>%;"
           aria-label="Reservado"></div>
         <div class="progress-bar"
           style="background-color: #ef6c79; width: <%= number_with_precision(@tile_status_percentages['rejected'], precision: 2) %>%;"
           aria-label="Reprovado"></div>
         <div class="progress-bar"
             style="background-color: #ced4da; width: <%= number_with_precision(@tile_status_percentages['available'], precision: 2) %>%;"
           aria-label="Disponível"></div>
      </div>

      <div class="d-flex flex-wrap gap-3 small">
        <span><span class="badge" style="background-color: #14532d; color: #fff;">Pago</span> <%= @tile_status_counts['paid'] %></span>
        <span><span class="badge" style="background-color: #9dbb4a; color: #212529;">Pagamento solicitado</span> <%= @tile_status_counts['payment_requested'] %></span>
        <span><span class="badge" style="background-color: #4caf50; color: #fff;">Aprovado</span> <%= @tile_status_counts['approved'] %></span>
        <span><span class="badge" style="background-color: #4f83cc; color: #fff;">Em revisão</span> <%= @tile_status_counts['in_review'] %></span>
        <span><span class="badge" style="background-color: #ffd54f; color: #212529;">Reservado</span> <%= @tile_status_counts['reserved'] %></span>
        <span><span class="badge" style="background-color: #ef6c79; color: #fff;">Reprovado</span> <%= @tile_status_counts['rejected'] %></span>
        <span><span class="badge" style="background-color: #ced4da; color: #212529;">Disponível</span> <%= @tile_status_counts['available'] %></span>
      </div>
    </div>
  </div>
<% end %>

<% if current_user.annotator? %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h2 class="h6 mb-0">Contas do annotator</h2>
        <span class="small text-muted">Mínimo para solicitar: <strong><%= number_to_currency(@min_payment_reais, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></strong></span>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-6 col-xl-3">
          <div class="border rounded p-3 h-100">
            <div class="small text-muted">Total aprovado</div>
            <div class="h5 mb-0"><%= number_to_currency(@approved_tasks_total_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></div>
          </div>
        </div>
        <div class="col-md-6 col-xl-3">
          <div class="border rounded p-3 h-100">
            <div class="small text-muted">Pagamento solicitado</div>
            <div class="h5 mb-0"><%= number_to_currency(@requested_payment_total_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></div>
          </div>
        </div>
        <div class="col-md-6 col-xl-3">
          <div class="border rounded p-3 h-100">
            <div class="small text-muted">Total a receber</div>
            <div class="h5 mb-0"><%= number_to_currency(@to_receive_total_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></div>
          </div>
        </div>
        <div class="col-md-6 col-xl-3">
          <div class="border rounded p-3 h-100">
            <div class="small text-muted">Total já pago</div>
            <div class="h5 mb-0"><%= number_to_currency(@paid_tasks_total_value, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></div>
          </div>
        </div>
      </div>

      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
        <h3 class="h6 mb-0">Tarefas aprovadas</h3>
        <%= button_to 'Requerer pagamento',
                      request_payment_dashboard_path,
                      method: :post,
                      class: 'btn btn-primary',
                      disabled: !@can_request_payment,
                      form: { class: 'd-inline-block mb-0' } %>
      </div>

      <% unless @can_request_payment %>
        <p class="small text-muted mb-2">O botão é liberado quando o total a receber atingir o valor mínimo.</p>
      <% end %>

      <% if @approved_annotations.any? %>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Tile</th>
                <th>Arquivo</th>
                <th>Valor</th>
              </tr>
            </thead>
            <tbody>
              <% @approved_annotations.each do |annotation| %>
                <% tile = annotation.image %>
                <tr>
                  <td>#<%= tile.id %></td>
                  <td><%= link_to tile.original_filename, tile_path(tile), class: 'link-primary text-decoration-none' %></td>
                  <td><%= number_to_currency(tile.task_value.to_d, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="alert alert-info mb-0">Você ainda não possui tarefas aprovadas para pagamento.</div>
      <% end %>

      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-4 mb-2">
        <h3 class="h6 mb-0">Tarefas pagas</h3>
      </div>

      <% if @paid_annotations.any? %>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Tile</th>
                <th>Arquivo</th>
                <th>Valor</th>
              </tr>
            </thead>
            <tbody>
              <% @paid_annotations.each do |annotation| %>
                <% tile = annotation.image %>
                <tr>
                  <td>#<%= tile.id %></td>
                  <td><%= link_to tile.original_filename, tile_path(tile), class: 'link-primary text-decoration-none' %></td>
                  <td><%= number_to_currency(tile.task_value.to_d, unit: 'R$', separator: ',', delimiter: '.', format: '%u%n') %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="alert alert-info mb-0">Você ainda não possui tarefas pagas.</div>
      <% end %>
    </div>
  </div>
<% end %>
