<% content_for :title, "Upload de Tile" %>

<div class="row justify-content-center">
  <div class="col-md-7 col-lg-6">
    <div class="card shadow-sm border-0 mt-5">
      <div class="card-body p-4">
        <h2 class="mb-4 text-center"><i class="bi bi-upload"></i> Upload de Tile</h2>
        <%= form_with url: tiles_path, method: :post, local: true, html: { multipart: true, class: "needs-validation" } do |f| %>
          <div class="mb-3">
            <%= f.label :file, "Arquivo do Tile", class: "form-label" %>
            <%= f.file_field :file, class: "form-control", required: true %>
          </div>
          <p class="text-muted mb-3">O valor da tarefa é calculado automaticamente pela contagem estimada de cabeças.</p>
          <div class="d-grid gap-2">
            <%= f.submit "Enviar", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
